# Second Brain - Environment Variables
#
# Copy this file to .env and fill in your values.
# .env is gitignored; never commit credentials.

# ============================================================
# Atlassian Cloud (Confluence + Jira on the same tenant)
# ============================================================

# Tenant URL (no trailing slash)
ATLASSIAN_SITE_URL=https://yourcompany.atlassian.net

# Your email
ATLASSIAN_EMAIL=your.email@yourcompany.com

# Authentication: set whichever your tenant allows.
# Personal API token (https://id.atlassian.com/manage-profile/security/api-tokens):
ATLASSIAN_API_TOKEN=

# OAuth 2.0 (if your tenant requires SSO-respecting auth):
# ATLASSIAN_OAUTH_CLIENT_ID=
# ATLASSIAN_OAUTH_CLIENT_SECRET=

# ============================================================
# Atlassian Remote MCP Server (alternative ingestion path)
# ============================================================
# Leave blank if you are using the API path (default for v1).
# ATLASSIAN_MCP_URL=

# ============================================================
# Vault and runtime paths (defaults are repo-relative)
# ============================================================

# SECONDBRAIN_VAULT_PATH=.
# SECONDBRAIN_LOG_PATH=wiki/log.md

# ============================================================
# Optional: cost tracking ceilings (advisory; not enforced)
# ============================================================

# SECONDBRAIN_MONTHLY_BUDGET_USD=

# ============================================================
# Notes
# ============================================================
# - LLM access is via your installed Copilot agent (or Claude Code, Cursor, Windsurf);
#   no separate Anthropic or OpenAI API key is required for v1.
# - Defuddle (vendor doc fetcher) is installed via npm: npm install -g defuddle
# - Vendor TTL and Confluence sync cadence are configured in config/second-brain.yml,
#   not here.

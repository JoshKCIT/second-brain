# Second Brain - .gitignore

# Secrets
.env
.env.local
*.secret

# Personal config (user-specific overrides)
config/second-brain.yml
config/platform-research-review.yml

# Runtime content (per-user; never shared)
raw/workspace-confluence/*
raw/workspace-jira/*
raw/platform-transcripts/*
!raw/workspace-confluence/.gitkeep
!raw/workspace-jira/.gitkeep
!raw/platform-transcripts/.gitkeep
# raw/workspace-external/ — tracked: shared vendor doc caches (AWS, Snowflake, IBM, etc.)

wiki/workspace-standards/*
wiki/workspace-recommendations/*
wiki/workspace-informational/*
wiki/workspace-concepts/*
wiki/workspace-connections/*
wiki/workspace-qa/*
wiki/platform-research/*
wiki/workspace-projects/*
wiki/workspace-archives/*
!wiki/workspace-standards/.gitkeep
!wiki/workspace-recommendations/.gitkeep
!wiki/workspace-informational/.gitkeep
!wiki/workspace-concepts/.gitkeep
!wiki/workspace-connections/.gitkeep
!wiki/workspace-qa/.gitkeep
!wiki/platform-research/.gitkeep
!wiki/platform-research/transcript-analyses/
!wiki/platform-research/transcript-analyses/.gitkeep
!wiki/platform-research/transcript-register.md
!wiki/platform-research/claim-register.md
!wiki/platform-research/rejected-ideas.md
!wiki/platform-research/open-hypotheses.md
!wiki/platform-research/implementation-backlog.md
!wiki/platform-research/intake-maps/
!wiki/platform-research/intake-maps/.gitkeep
!wiki/workspace-projects/.gitkeep
!wiki/workspace-archives/.gitkeep

# Wiki views may be tracked or per-user; default tracked (Bases are user-curated)
# Uncomment to ignore if you prefer per-user Bases:
# wiki/workspace-views/*
# !wiki/workspace-views/.gitkeep

# Wiki index and log are per-user (your knowledge state)
wiki/index.md
wiki/log.md

# Runtime output
confluence-review/
quarantine/*
!quarantine/README.md
reports/*
!reports/platform-research-review/
!reports/platform-research-review/.gitkeep

# State tracking (gitignored; regenerated)
state.json
last-flush.json

# Build inputs (planning-time references; not part of shipped repo functionality)
build-inputs/
building-second-brain-reference-docs/

# Reference documents folder (manual drops of external standards)
reference-documents/*
!reference-documents/.gitkeep
!reference-documents/README.md

# Temp files
*.tmp
*.bak
*~
.DS_Store
Thumbs.db

# Local claim-extraction scratch (platform research sessions)
scripts/_claims_*.yaml

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.pytest_cache/

# Node (if scripts use Node tooling)
node_modules/
package-lock.json
yarn.lock

# IDE
.vscode/
.idea/
*.swp
*.swo

# Obsidian per-user state (the bundled .obsidian/ defaults are tracked;
# user-specific workspace state is not)
.obsidian/workspace.json
.obsidian/workspaces.json
.obsidian/cache
.obsidian/.cache
